    "GET /analyses - List recent analyses",
    "POST /report/pdf - Generate PDF report from markdown content",
    "AnalysisOrchestrator.analyze() - Main orchestration entry point",
    "GitHubClient.get_repo_metadata() - Fetch repository metadata",
    "OpenRouterClient.complete() - LLM completion with multi-key rotation",
    "TrendMaster.enrich_with_trends() - Trend intelligence enrichment",
